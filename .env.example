# ============================================
# DATABASE CREDENTIALS
# ============================================
# Phải khớp với docker-compose.yml

MYSQL_PASS=changeme_mysql_password

MONGO_USER=admin
MONGO_PASS=changeme_mongo_password

PG_USER=admin
PG_PASS=changeme_pg_password
PG_DB=admin_db

# ============================================
# NGINX HTPASSWD (basic auth)
# ============================================
HTPASSWD_USER=admin
HTPASSWD_PASS=changeme_htpasswd_password

# ============================================
# REDIS INSIGHT
# ============================================

REDIS_INSIGHT_USERNAME=admin
REDIS_INSIGHT_PASSWORD=changeme_redisinsight_password

# ============================================
# RABBITMQ
# ============================================

RABBITMQ_USER=admin
RABBITMQ_PASS=changeme_rabbitmq_password

# ============================================
# MONGO EXPRESS
# ============================================

ME_BASICAUTH_USER=admin
ME_BASICAUTH_PASS=changeme_mongoexpress_password

# ============================================
# PGADMIN
# ============================================

PGADMIN_EMAIL=your_email@example.com
PGADMIN_PASS=changeme_pgadmin_password

# ============================================
# BACKUP CONFIG
# ============================================

# Tên remote rclone (tạo bằng `rclone config`)
RCLONE_REMOTE=gdrive:db-backups

# Số ngày giữ backup
LOCAL_RETENTION_DAYS=7
DRIVE_RETENTION_DAYS=30

# Giờ chạy cron (giờ:phút, 24h format)
CRON_HOUR=4
CRON_MINUTE=0

# ============================================
# CONTAINER NAMES (phải khớp docker-compose.yml)
# ============================================

MYSQL_CONTAINER=mysql-nro
MONGO_CONTAINER=mongo
POSTGRES_CONTAINER=postgres
REDIS_CONTAINER=redis